{
	"name": "shaderpad",
	"version": "1.0.0-beta.78",
	"description": "A lightweight, dependency-free library to reduce boilerplate when writing fragment shaders.",
	"keywords": [
		"shaders",
		"webgl",
		"frontend"
	],
	"author": "rileyjshaw",
	"license": "MIT",
	"repository": "github:miseryco/shaderpad",
	"homepage": "https://misery.co/shaderpad/",
	"bugs": "https://github.com/miseryco/shaderpad/issues",
	"main": "./dist/index.js",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"development": {
				"import": "./dist/dev/index.mjs",
				"require": "./dist/dev/index.js"
			},
			"import": "./dist/index.mjs",
			"require": "./dist/index.js"
		},
		"./react": {
			"types": "./dist/react.d.ts",
			"development": {
				"import": "./dist/dev/react.mjs",
				"require": "./dist/dev/react.js"
			},
			"import": "./dist/react.mjs",
			"require": "./dist/react.js"
		},
		"./web-component": {
			"types": "./dist/web-component.d.ts",
			"development": {
				"import": "./dist/dev/web-component.mjs",
				"require": "./dist/dev/web-component.js"
			},
			"import": "./dist/web-component.mjs",
			"require": "./dist/web-component.js"
		},
		"./plugins/face": {
			"types": "./dist/plugins/face.d.ts",
			"development": {
				"import": "./dist/dev/plugins/face.mjs",
				"require": "./dist/dev/plugins/face.js"
			},
			"import": "./dist/plugins/face.mjs",
			"require": "./dist/plugins/face.js"
		},
		"./plugins/helpers": {
			"types": "./dist/plugins/helpers.d.ts",
			"development": {
				"import": "./dist/dev/plugins/helpers.mjs",
				"require": "./dist/dev/plugins/helpers.js"
			},
			"import": "./dist/plugins/helpers.mjs",
			"require": "./dist/plugins/helpers.js"
		},
		"./helpers/*.glsl": {
			"types": "./dist/helpers/*.glsl.d.ts",
			"default": "./dist/helpers/*.glsl"
		},
		"./plugins/pose": {
			"types": "./dist/plugins/pose.d.ts",
			"development": {
				"import": "./dist/dev/plugins/pose.mjs",
				"require": "./dist/dev/plugins/pose.js"
			},
			"import": "./dist/plugins/pose.mjs",
			"require": "./dist/plugins/pose.js"
		},
		"./plugins/hands": {
			"types": "./dist/plugins/hands.d.ts",
			"development": {
				"import": "./dist/dev/plugins/hands.mjs",
				"require": "./dist/dev/plugins/hands.js"
			},
			"import": "./dist/plugins/hands.mjs",
			"require": "./dist/plugins/hands.js"
		},
		"./plugins/segmenter": {
			"types": "./dist/plugins/segmenter.d.ts",
			"development": {
				"import": "./dist/dev/plugins/segmenter.mjs",
				"require": "./dist/dev/plugins/segmenter.js"
			},
			"import": "./dist/plugins/segmenter.mjs",
			"require": "./dist/plugins/segmenter.js"
		},
		"./plugins/autosize": {
			"types": "./dist/plugins/autosize.d.ts",
			"development": {
				"import": "./dist/dev/plugins/autosize.mjs",
				"require": "./dist/dev/plugins/autosize.js"
			},
			"import": "./dist/plugins/autosize.mjs",
			"require": "./dist/plugins/autosize.js"
		},
		"./util": {
			"types": "./dist/util.d.ts",
			"development": {
				"import": "./dist/dev/util.mjs",
				"require": "./dist/dev/util.js"
			},
			"import": "./dist/util.mjs",
			"require": "./dist/util.js"
		}
	},
	"typesVersions": {
		"*": {
			"react": [
				"dist/react.d.ts"
			],
			"web-component": [
				"dist/web-component.d.ts"
			],
			"plugins/face": [
				"dist/plugins/face.d.ts"
			],
			"plugins/helpers": [
				"dist/plugins/helpers.d.ts"
			],
			"helpers/*.glsl": [
				"dist/helpers/*.glsl.d.ts"
			],
			"plugins/pose": [
				"dist/plugins/pose.d.ts"
			],
			"plugins/hands": [
				"dist/plugins/hands.d.ts"
			],
			"plugins/segmenter": [
				"dist/plugins/segmenter.d.ts"
			],
			"plugins/autosize": [
				"dist/plugins/autosize.d.ts"
			],
			"util": [
				"dist/util.d.ts"
			]
		}
	},
	"sideEffects": false,
	"files": [
		"dist"
	],
	"scripts": {
		"prebuild": "node ../../scripts/generate-error-code-artifacts.mjs",
		"build": "tsup",
		"postbuild": "node ./scripts/copy-helper-glsl.mjs"
	},
	"peerDependencies": {
		"@mediapipe/tasks-vision": "*",
		"react": ">=18"
	},
	"peerDependenciesMeta": {
		"@mediapipe/tasks-vision": {
			"optional": true
		},
		"react": {
			"optional": true
		}
	},
	"devDependencies": {
		"@types/react": "^19.2.2",
		"react": "^19.2.3"
	},
	"publishConfig": {
		"access": "public"
	}
}
