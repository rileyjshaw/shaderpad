{
	"name": "shaderpad-workspace",
	"private": true,
	"workspaces": [
		"packages/*",
		"docs"
	],
	"scripts": {
		"build": "npm run build --workspace shaderpad",
		"docs": "npm run docs:dev",
		"docs:build": "npm run build --workspace shaderpad-docs",
		"docs:dev": "npm run dev --workspace shaderpad-docs",
		"docs:start": "npm run start --workspace shaderpad-docs",
		"release": "node scripts/release.mjs",
		"size:exports": "node scripts/size-standard-import.mjs",
		"size:standard-import": "npm run size:exports",
		"format": "prettier --write \"./**/*.{ts,js,tsx,jsx,html,css,json,md}\""
	},
	"devDependencies": {
		"@changesets/changelog-github": "^0.6.0",
		"@changesets/cli": "^2.30.0",
		"prettier": "^3.8.2",
		"tsup": "^8.5.1",
		"typescript": "^6.0.2"
	}
}
